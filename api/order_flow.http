### ORDER_ID_FROM_STEP_1
### END-TO-END ORDER FLOW WITH SOLVER INTEGRATION

# This file documents the standard flow for a delivery order
# 1. NEW -> CONFIRMED (Staff confirm)
# 2. CONFIRMED -> PREPARING (Solver schedules kitchen and VRP)
# 3. PREPARING -> READY (Kitchen finishes or deadline reached)
# 4. READY -> DELIVERING (Shipper picks up based on route)
# 5. DELIVERING -> COMPLETED (Shipper finishes)

# NEW SCHEMA NOTES:
# - chefId & expectedReadyAt are in the root of the Order response.
# - shipperId & deliverySequence are nested inside the 'delivery' object.


### STEP 1: Customer Creates a Delivery Order
# Status: NEW
POST http://localhost:5001/api/v1/orders
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  // "storeId": "{{storeId}}",
  "type": "DELIVERY",
  "note": "Please deliver to my home (Solver assigns store)",
  "deliveryInfo": {
    "receiverName": "Customer Name",
    "receiverPhone": "0987654321",
    "addressLine": "10 Nguyen Thi Minh Khai, Quan 1, Ho Chi Minh City"
  },
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 2
    }
  ]
}

### STEP 2: Staff Confirms the Order
# Status: NEW -> CONFIRMED
PATCH http://localhost:5001/api/v1/internal/orders/{{orderId4}}/status
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "status": "CONFIRMED"
}

### STEP 3: Get Unified Schedule (Solver)
# Solver looks for CONFIRMED/PREPARING Delivery Orders and:
# 1. Assigns Kitchen Staff (chefId in root)
# 2. Assigns Shippers and calculates delivery routes (shipperId & sequence in 'delivery' object)
# Status: CONFIRMED -> PREPARING (Assignment determined)
POST http://localhost:5001/api/v1/internal/kitchen/schedule
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "tardiness_weight": 1000
}

# Example Response Extract:
# {
#   "data": {
#     "orderCode": "VD-DE-12345",
#     "chefId": "uuid-chef-1",
#     "expectedReadyAt": "2026-06-07T14:30:00.000Z",
#     "delivery": {
#       "shipperId": "uuid-shipper-2",
#       "deliverySequence": 1,
#       "status": "PENDING"
#     }
#   }
# }


### STEP 4: Physical Status Transitions
# Once assignments are known, orders move through these stages:

# A. Start Preparation
PATCH http://localhost:5001/api/v1/internal/orders/{{orderId}}/status
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{ "status": "PREPARING" }

# B. Finish Preparation
PATCH http://localhost:5001/api/v1/internal/orders/{{orderId1}}/status
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{ "status": "READY" }

### STEP 5: Shipper Picks Up and Marks as DELIVERING
# Status: READY -> DELIVERING
PATCH http://localhost:5001/api/v1/internal/orders/{{orderId}}/status
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "status": "DELIVERING"
}

### STEP 7: Shipper Completes Delivery
# Status: DELIVERING -> COMPLETED
PATCH http://localhost:5001/api/v1/internal/orders/{{orderId}}/status
Authorization: Bearer {{staffToken}}
Content-Type: application/json

{
  "status": "COMPLETED"
}
